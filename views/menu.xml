<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Client Action: Dashboard -->
    <record id="action_remote_dashboard" model="ir.actions.client">
        <field name="name">Dashboard Remoto</field>
        <field name="tag">remote_dashboard.dashboard</field>
    </record>

    <!-- Menu principal -->
    <menuitem id="menu_remote_dashboard_root"
              name="Dashboard Remoto"
              sequence="1"/>

    <menuitem id="menu_remote_dashboard"
              name="Dashboard"
              parent="menu_remote_dashboard_root"
              action="action_remote_dashboard"
              sequence="1"/>

    <menuitem id="menu_remote_tableros"
              name="Tableros"
              parent="menu_remote_dashboard_root"
              action="action_remote_tableros"
              sequence="5"/>

    <menuitem id="menu_remote_config"
              name="Configuración"
              parent="menu_remote_dashboard_root"
              sequence="90"/>

    <menuitem id="menu_remote_config_connection"
              name="Dashboards"
              parent="menu_remote_config"
              action="action_remote_config"
              sequence="1"/>

    <menuitem id="menu_remote_log"
              name="Log de Cambios"
              parent="menu_remote_dashboard_root"
              action="action_remote_odoo_log"
              sequence="50"/>

</odoo>
