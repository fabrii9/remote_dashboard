<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree view -->
    <record id="view_remote_odoo_log_tree" model="ir.ui.view">
        <field name="name">remote.odoo.log.tree</field>
        <field name="model">remote.odoo.log</field>
        <field name="arch" type="xml">
            <tree string="Log de Cambios" default_order="timestamp desc">
                <field name="timestamp"/>
                <field name="event_type"/>
                <field name="picking_name"/>
                <field name="partner_name"/>
                <field name="origin"/>
                <field name="column_type"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_remote_odoo_log_search" model="ir.ui.view">
        <field name="name">remote.odoo.log.search</field>
        <field name="model">remote.odoo.log</field>
        <field name="arch" type="xml">
            <search string="Buscar Log">
                <field name="picking_name" string="Picking"/>
                <field name="partner_name" string="Cliente"/>
                <field name="origin" string="Pedido"/>
                <separator/>
                <filter name="filter_new" string="Nuevos"
                        domain="[('event_type', '=', 'new')]"/>
                <filter name="filter_state" string="Cambio de estado"
                        domain="[('event_type', '=', 'state_change')]"/>
                <filter name="filter_sub_state" string="Cambio de sub-estado"
                        domain="[('event_type', '=', 'sub_state_change')]"/>
                <filter name="filter_column" string="Cambio de columna"
                        domain="[('event_type', '=', 'column_change')]"/>
                <filter name="filter_completed" string="Completados"
                        domain="[('event_type', '=', 'completed')]"/>
                <separator/>
                <filter name="filter_today" string="Hoy"
                        domain="[('timestamp', '>=', (context_today()).strftime('%%Y-%%m-%%d'))]"/>
                <separator/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_event" string="Tipo de Evento"
                            context="{'group_by': 'event_type'}"/>
                    <filter name="group_column" string="Columna"
                            context="{'group_by': 'column_type'}"/>
                    <filter name="group_date" string="Fecha"
                            context="{'group_by': 'timestamp:day'}"/>
                    <filter name="group_picking" string="Picking"
                            context="{'group_by': 'picking_name'}"/>
                    <filter name="group_origin" string="Pedido"
                            context="{'group_by': 'origin'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_remote_odoo_log" model="ir.actions.act_window">
        <field name="name">Log de Cambios</field>
        <field name="res_model">remote.odoo.log</field>
        <field name="view_mode">tree</field>
        <field name="context">{'search_default_filter_today': 1}</field>
    </record>

</odoo>
